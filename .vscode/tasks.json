      "label": "install vsdbg (api)",
      "type": "shell",
      "command": "docker exec -i yeppet-api bash -lc 'if [ ! -x /vsdbg/vsdbg ]; then mkdir -p /vsdbg && curl -sSL https://aka.ms/getvsdbgsh | bash /dev/stdin -v latest -l /vsdbg; fi'",
